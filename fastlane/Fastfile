default_platform(:mac)

platform :mac do
  desc "Prepara, gera a build do macOS e envia para o App Store Connect (TestFlight / App Store)"
  lane :release do |options|
    # Exige que as variáveis de ambiente com as credenciais do App Store Connect API estejam presentes
    # Ou que o usuário informe via parâmetros da lane.
    key_id = ENV["ASC_KEY_ID"] || options[:key_id]
    issuer_id = ENV["ASC_ISSUER_ID"] || options[:issuer_id]
    key_content = ENV["ASC_KEY_CONTENT"] || options[:key_content] # Chave .p8 em formato de texto base64 ou raw string
    key_filepath = ENV["ASC_KEY_FILEPATH"] || options[:key_filepath] # ou caminho físico da chave .p8

    unless (key_id && issuer_id && (key_content || key_filepath))
      UI.user_error!("Por favor, configure as variáveis de ambiente (ASC_KEY_ID, ASC_ISSUER_ID, e ASC_KEY_CONTENT ou ASC_KEY_FILEPATH) ou passe-as como parâmetro.")
    end

    # 1. Carrega a chave da API do App Store Connect
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_filepath,
      key_content: key_content,
      duration: 1200,
      in_house: false
    )

    # 2. Incrementa o build number (CURRENT_PROJECT_VERSION) no project.pbxproj
    # Nota: Para o 'increment_build_number' funcionar com macOS, precisamos do agvtool ou podemos fazer o incremento manual via script.
    # Vamos usar o helper 'increment_build_number' padrão do fastlane (que gerencia plist/pbxproj).
    begin
      increment_build_number(
        xcodeproj: "GalaxyBudsMac/GalaxyBudsMac.xcodeproj"
      )
    rescue => e
      UI.important("Não foi possível usar o increment_build_number automático: #{e.message}. Tentando incrementar usando script customizado.")
      # Script alternativo caso agvtool não esteja configurado
      sh("cd GalaxyBudsMac && xcrun agvtool next-version -all")
    end

    # 3. Compila e gera o archive (.pkg) pronto para a App Store
    # Usamos o helper de macOS build_mac_app (que é o gym para macOS)
    build_mac_app(
      project: "GalaxyBudsMac/GalaxyBudsMac.xcodeproj",
      scheme: "GalaxyBudsMac",
      export_method: "app-store",
      output_directory: "fastlane/builds",
      output_name: "BudsConnect"
    )

    # 4. Envia o build para o TestFlight / App Store Connect
    # Se você quiser que o build seja enviado direto para o review da App Store,
    # pode usar o upload_to_app_store. Para TestFlight, usamos upload_to_testflight.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
